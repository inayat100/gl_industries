<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================= -->
    <!-- Google Sheet Configuration Tree -->
    <!-- ============================= -->
    <record id="view_google_sheet_configuration_tree" model="ir.ui.view">
        <field name="name">google.sheet.configuration.tree</field>
        <field name="model">google.sheet.configuration</field>
        <field name="arch" type="xml">
            <list string="Google Sheet Configurations">
                <field name="name"/>
                <field name="spreadsheet_id"/>
                <field name="spreadsheet_state"/>
            </list>
        </field>
    </record>

