    <!-- ============================= -->
    <!-- Google Sheet Configuration Search -->
    <!-- ============================= -->
    <record id="view_google_sheet_configuration_search" model="ir.ui.view">
        <field name="name">google.sheet.configuration.search</field>
        <field name="model">google.sheet.configuration</field>
        <field name="arch" type="xml">
            <search string="Search Google Sheet Configurations">
                <field name="name"/>
                <field name="spreadsheet_state"/>
            </search>
        </field>
    </record>


    <!-- ============================= -->
    <!-- Action: Google Sheet Configuration -->
    <!-- ============================= -->
    <record id="action_google_sheet_configuration" model="ir.actions.act_window">
        <field name="name">Google Sheet Configuration</field>
        <field name="res_model">google.sheet.configuration</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_google_sheet_configuration_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Google Sheet Configuration
            </p>
        </field>
    </record>


    <!-- ============================= -->
    <!-- Menus -->
    <!-- ============================= -->

    <menuitem
            id="menu_google_sheet_configuration"
            name="Sheet Configuration"
            parent="ir_google_sheet.menu_api_report_root"
            action="action_google_sheet_configuration"
            sequence="15"
    />


</odoo>