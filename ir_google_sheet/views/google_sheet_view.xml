<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         Google Sheet Tree View
    ========================== -->
    <record id="view_google_sheet_tree" model="ir.ui.view">
        <field name="name">google.sheet.tree</field>
        <field name="model">google.sheet</field>
        <field name="arch" type="xml">
            <list string="Google Sheets">
                <field name="name"/>
                <field name="state"/>
                <field name="report_configuration_id"/>
                <field name="google_sheet_configuration_id"/>
            </list>
        </field>
    </record>

    <!-- =========================
         Google Sheet Form View
    ========================== -->
    <record id="view_google_sheet_form" model="ir.ui.view">
        <field name="name">google.sheet.form</field>
        <field name="model">google.sheet</field>
        <field name="arch" type="xml">
            <form string="Google Sheet">
                <header>
                    <button type="object" name="test_api_connection" string="Test Connection"
                            class="btn btn-primary"/>
                    <button type="object" name="action_send_data" string="Send Data"
                            class="btn btn-primary"/>
                    <button type="object" name="action_delete_google_sheet" string="Delete Sheet"
                            class="btn btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,connect,failed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="id" invisible="1"/>
                            <field name="name"/>
                            <field name="mode"/>
                            <field name="match_field" options='{"no_create": True}'
                                   domain="[('add_sheet', '=', True), ('google_sheet_id', '=', id)]"/>
                        </group>
                        <group>
                            <field name="report_configuration_id" options='{"no_create": True}'/>
                            <field name="google_sheet_configuration_id" options='{"no_create": True}'
                                   domain="[('spreadsheet_state', '=', 'connect')]"/>
                            <group string="Auto Sync">
                                <field name="auto_sync"/>
                                <field name="sync_interval_number" invisible="not auto_sync"/>
                                <field name="sync_interval_type" invisible="not auto_sync"/>
                                <field name="next_sync_at" readonly="1"/>
                                <field name="last_sync_at" readonly="1"/>
                                <field name="last_sync_status" readonly="1"/>
                                <field name="last_sync_message" readonly="1"/>
                            </group>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sheet Lines">
                            <field name="sheet_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="field_name"/>
                                    <field name="field_head"/>
<!--                                    <field name="field_style"/>-->
                                    <field name="col_name"/>
                                    <field name="add_sheet"/>
                                    <field name="is_sum"/>
                                </list>
                            </field>
                        </page>
                        <page string="Filters">
                            <field name="filter_line_ids" nolabel="1">
                                <list>
                                    <field name="sheet_line_id" force_save="1" options='{"no_create": True}'/>
                                    <field name="domain_type" force_save="1" readonly="1"/>
                                    <field name="operator" force_save="1"/>
                                    <field name="number_operator" force_save="1"/>
                                    <field name="value_text" invisible="domain_type != 'name'" force_save="1"/>
                                    <field name="suggested_value_ids" widget="many2many_tags" force_save="1" invisible="domain_type != 'name'"/>
                                    <field name="value_number" force_save="1" invisible="domain_type != 'number'"/>
                                    <field name="active"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="domain_type" force_save="1"/>
                                            <field name="operator" force_save="1" invisible="domain_type != 'name'"/>
                                            <field name="number_operator" force_save="1" invisible="domain_type != 'number'"/>
                                        </group>
                                        <group>
                                            <field name="sheet_line_id" force_save="1"/>
                                            <field name="value_number" force_save="1" invisible="domain_type != 'number'"/>
                                            <field name="value_text" force_save="1" invisible="domain_type != 'name'"/>
                                            <field name="suggested_value_ids" force_save="1" invisible="domain_type != 'name'" widget="many2many_tags"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Preview Json">
                            <field name="json_data_text"/>
                        </page>
                        <page string="Preview Data">
                            <field name="json_data_html"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================
         Google Sheet Search View
    ========================== -->
    <record id="view_google_sheet_search" model="ir.ui.view">
        <field name="name">google.sheet.search</field>
        <field name="model">google.sheet</field>
        <field name="arch" type="xml">
            <search string="Search Google Sheets">
                <field name="name"/>
                <field name="state"/>
                <field name="report_configuration_id"/>
                <field name="google_sheet_configuration_id"/>

                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Connected" name="filter_connected" domain="[('state', '=', 'connect')]"/>
                <filter string="Failed" name="filter_failed" domain="[('state', '=', 'failed')]"/>

                <group expand="0" string="Group By">
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Report Configuration" name="group_by_report_configuration"
                            context="{'group_by': 'report_configuration_id'}"/>
                    <filter string="Sheet Configuration" name="group_by_google_sheet_configuration"
                            context="{'group_by': 'google_sheet_configuration_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- =========================
         Google Sheet Line Tree View
    ========================== -->
    <record id="view_google_sheet_line_tree" model="ir.ui.view">
        <field name="name">google.sheet.line.tree</field>
        <field name="model">google.sheet.line</field>
        <field name="arch" type="xml">
            <list string="Google Sheet Lines">
                <field name="google_sheet_id"/>
                <field name="field_name"/>
                <field name="field_head"/>
<!--                <field name="field_style"/>-->
                <field name="col_name"/>
                <field name="add_sheet"/>
                <field name="is_sum"/>
                <!--                <field name="is_formula"/>-->
                <!--                <field name="formula"/>-->
            </list>
        </field>
    </record>

    <!-- =========================
         Google Sheet Line Form View
    ========================== -->
    <record id="view_google_sheet_line_form" model="ir.ui.view">
        <field name="name">google.sheet.line.form</field>
        <field name="model">google.sheet.line</field>
        <field name="arch" type="xml">
            <form string="Google Sheet Line">
                <sheet>
                    <group>
                        <group>
                            <field name="google_sheet_id" options='{"no_create": True}'/>
                            <field name="field_name"/>
                            <field name="field_head"/>
                            <field name="col_name"/>
                        </group>
                        <group>
<!--                            <field name="field_style"/>-->
                            <field name="add_sheet"/>
                            <field name="is_sum"/>
                            <!--                            <field name="is_formula"/>-->
                            <!--                            <field name="formula" required="is_formula" invisible="not is_formula"/>-->
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================
         Google Sheet Line Search View
    ========================== -->
    <record id="view_google_sheet_line_search" model="ir.ui.view">
        <field name="name">google.sheet.line.search</field>
        <field name="model">google.sheet.line</field>
        <field name="arch" type="xml">
            <search string="Search Google Sheet Lines">
                <field name="google_sheet_id"/>
                <field name="field_name"/>
                <field name="field_head"/>
                <field name="col_name"/>

                <filter string="Add Sheet" name="filter_add_sheet" domain="[('add_sheet', '=', True)]"/>
                <!--                <filter string="Formula" name="filter_formula" domain="[('is_formula', '=', True)]"/>-->

                <group expand="0" string="Group By">
                    <filter string="Google Sheet" name="group_by_google_sheet"
                            context="{'group_by': 'google_sheet_id'}"/>
                    <!--                    <filter string="Formula" name="group_by_is_formula" context="{'group_by': 'is_formula'}"/>-->
                </group>
            </search>
        </field>
    </record>

    <!-- =========================
         Actions
    ========================== -->
    <record id="action_google_sheet" model="ir.actions.act_window">
        <field name="name">Google Sheets</field>
        <field name="res_model">google.sheet</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_google_sheet_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Google Sheet.
            </p>
        </field>
    </record>

    <record id="action_google_sheet_line" model="ir.actions.act_window">
        <field name="name">Google Sheet Lines</field>
        <field name="res_model">google.sheet.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_google_sheet_line_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Google Sheet Line.
            </p>
        </field>
    </record>

    <!-- =========================
         Menus
    ========================== -->

    <!-- If you already have a root menu, use that as parent -->

    <menuitem
            id="menu_google_sheet"
            name="Google Sheets"
            parent="ir_google_sheet.menu_api_report_root"
            action="action_google_sheet"
            sequence="10"
    />

    <menuitem
            id="menu_google_sheet_line"
            name="Google Sheet Lines"
            parent="ir_google_sheet.menu_api_report_root"
            action="action_google_sheet_line"
            sequence="12"
    />

</odoo>