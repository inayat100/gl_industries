<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_api_report_configuration_tree" model="ir.ui.view">
        <field name="name">api.report.configuration.tree</field>
        <field name="model">api.report.configuration</field>
        <field name="arch" type="xml">
            <list string="API Report Configurations">
                <field name="name"/>
                <field name="company_id"/>
                <field name="server_url"/>
                <field name="user_name"/>
                <field name="report_type"/>
                <field name="period_from"/>
                <field name="period_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_api_report_configuration_form" model="ir.ui.view">
        <field name="name">api.report.configuration.form</field>
        <field name="model">api.report.configuration</field>
        <field name="arch" type="xml">
            <form string="API Report Configuration">
                <sheet>
                    <field name="is_odoo" invisible="1"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" options='{"no_create": True}'/>
                            <field name="active" invisible="is_odoo"/>
                            <field name="report_type" invisible="is_odoo"/>
                            <field name="location" invisible="is_odoo"/>
                        </group>
                        <group>
                            <field name="server_url"/>
                            <field name="user_name"/>
                            <field name="api_key"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Company Details" invisible="is_odoo">
                            <group>
                                <group>
                                    <field name="company_key"/>
                                    <field name="enterprise_id"/>
                                </group>
                                <group>
                                    <field name="user_id"/>
                                </group>
                            </group>
                        </page>

                        <page string="Period Details">
                            <group>
                                <group>
                                    <field name="period_from"/>
                                </group>
                                <group>
                                    <field name="period_to"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_api_report_configuration_search" model="ir.ui.view">
        <field name="name">api.report.configuration.search</field>
        <field name="model">api.report.configuration</field>
        <field name="arch" type="xml">
            <search string="Search API Report Configurations">
                <field name="name"/>
                <field name="company_id"/>
                <field name="user_name"/>
                <field name="report_type"/>
                <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="filter_inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Report Type" name="group_by_report_type" context="{'group_by': 'report_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_api_report_configuration" model="ir.actions.act_window">
        <field name="name">API Report Configuration</field>
        <field name="res_model">api.report.configuration</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_odoo', '=', False)]</field>
        <field name="context">{'default_is_odoo': False}</field>
        <field name="search_view_id" ref="view_api_report_configuration_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API Report Configuration
            </p>
        </field>
    </record>

    <record id="action_api_odoo_report_configuration" model="ir.actions.act_window">
        <field name="name">API Report Configuration</field>
        <field name="res_model">api.report.configuration</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_odoo', '=', True)]</field>
        <field name="context">{'default_is_odoo': True}</field>
        <field name="search_view_id" ref="view_api_report_configuration_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API Report Configuration
            </p>
        </field>
    </record>

    <!-- Parent Menu -->
    <menuitem
        id="menu_api_report_root"
        name="Google Sheet"
        sequence="10"
    />

    <!-- Child Menu -->
    <menuitem
        id="menu_api_report_configuration"
        name="Report Configuration"
        parent="menu_api_report_root"
        action="action_api_report_configuration"
        sequence="20"
    />

    <menuitem
        id="menu_api_odoo_report_configuration"
        name="Odoo Report Configuration"
        parent="menu_api_report_root"
        action="action_api_odoo_report_configuration"
        sequence="25"
    />

</odoo>